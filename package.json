{
  "name": "mnesti-blog-publisher",
  "version": "1.0.0",
  "description": "Automated daily blog publisher for mnesti.it",
  "scripts": {
    "publish":    "node scripts/publish.js",
    "new-branch": "bash scripts/new-branch.sh",
    "test":       "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit":  "node --test tests/unit/*.test.js",
    "test:int":   "node --test tests/integration/*.test.js",
    "test:watch": "node --test --watch tests/unit/*.test.js"
  },
  "engines": {
    "node": ">=18"
  }
}
